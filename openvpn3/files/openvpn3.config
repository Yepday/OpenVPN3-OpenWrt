# /etc/config/openvpn3 — UCI configuration for openvpn3d
#
# Add a 'config vpn' section for each VPN profile.
# Place the corresponding .ovpn file in /etc/openvpn3/.

# Example instance (disabled by default)
config vpn 'example'
	option enabled    '0'
	option config     '/etc/openvpn3/example.ovpn'
	# option dev      'tun0'      # optional: force interface name
	# option log_level '3'        # 0=fatal 1=error 2=warn 3=info 4=debug
